  ;; 2.SAO CHEP HATCH    
(defun c:HC (/ OLDOS ERR ENAME ELIST ETYPE OLD SOL PT1 LAYN)
  (setq OLDOS (getvar "OSMODE")) ; lưu trạng thái bắt điểm
  (setq ERR
    (vl-catch-all-apply
      '(lambda ( / )
         (setvar "MODEMACRO" "TNT Architecture")
         (command "_.UNDO" "_Begin")
         (setvar "CMDECHO" 0)
         (setq ENAME (entsel "\nCHON HATCH"))
         (if ENAME
           (progn
             (setq ELIST (entget (car ENAME))
                   ETYPE (cdr (assoc 0 ELIST))
                   OLD   (getvar "CLAYER")
             )
             (if (= ETYPE "HATCH")
               (progn
                 (setvar "OSMODE" 0)
                 (setq SOL (cdr (assoc 2 ELIST)))
                 (while (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
                   (setq LAYN (cdr (assoc 8 ELIST)))
                   (setvar "HPNAME"  (cdr (assoc 2 ELIST)))
                   (setvar "HPCOLOR" "BYLAYER")
                   (setvar "CLAYER"  LAYN)
                   (command "_.BHATCH" PT1 "")
                   (setvar "CLAYER" OLD)
                 )
               )
               (prompt "\nCHON LAI HATCH")
             )
           )
         )
         (command "_.UNDO" "_End")
       )
    )
  )
  ;; Dù lỗi hay không, luôn trả lại OSMODE
  (setvar "OSMODE" OLDOS)
  (setvar "CMDECHO" 1)
  (if (vl-catch-all-error-p ERR)
    (princ (strcat "\n[HC] Loi: " (vl-catch-all-error-message ERR)))
  )
  (princ)
)
  ;; 3.DI CHUYEN HATCH
    (defun c:HV (/ ENAME ELIST ETYPE OLD SOL LAYN PT1 )
      (setvar "MODEMACRO" "TNT Architecture")
      (setvar "CMDECHO" 0)
      (command "UNDO" "BE")      
      (setq ENAME (entsel "\nCHON HATCH")
            ELIST (entget (car ENAME))
            ETYPE (cdr (assoc 0 ELIST))
            OLD (getvar "CLAYER")        
      )
      (if (/= ETYPE "HATCH")
      (prompt "\nCHON LAI HATCH")
        (progn
          (setvar "OSMODE" 0)
          (setq SOL (setvar "HPNAME" (cdr (assoc 2 ELIST))))
          (if (/= SOL "SOLID")
            (progn
              (setq LAYN (cdr (assoc 8 ELIST)))
              (setvar "HPNAME" (cdr (assoc 2 ELIST)))
              (setvar "HPSCALE" (cdr (assoc 41 ELIST)))
              (setvar "HPANG" (cdr (assoc 52 ELIST)))
              (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
              (setvar "CLAYER" LAYN )
              (entdel (car ENAME))
              (command "BHATCH" PT1 "" )
              (setvar "CLAYER" OLD )
            )
            (progn
              (setq LAYN (cdr (assoc 8 ELIST)))
              (setvar "HPNAME" (cdr (assoc 2 ELIST)))
              (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
              (setvar "CLAYER" LAYN )
              (entdel (car ENAME))
              (command "BHATCH" PT1 "" )
              (setvar "CLAYER" OLD )
            )
          )
        )
      )
      (setvar "OSMODE" 15871)
      (setvar "CMDECHO" 1)
      (command "UNDO" "END")
      (princ)
    )
