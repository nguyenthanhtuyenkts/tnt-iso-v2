(vl-load-com)
(setvar "MODEMACRO" "010.α")
;;; ====================================================================================================
;;; [1] HÀM CON TẠO NÉT TRANG TRÍ HỘP THOẠI
;;; ====================================================================================================
(defun 010:DCL:SET_TILE_OF_SEP ( Tile / )
	(set_tile Tile "────────────────────────────────────────────────────────────────────────────────────")
	(mode_tile Tile 1)
)
(defun 010:DCL:SET_TILE_DECORATION ( NumTotal / Num Tile)
	(setq Num 0)
	(repeat NumTotal
		(setq Tile (strcat "sep" (itoa Num)))
		(set_tile Tile "──────────────────────────────────────────────────────────────────────────────────")
		(setq Num (+ Num 1))
	)
)