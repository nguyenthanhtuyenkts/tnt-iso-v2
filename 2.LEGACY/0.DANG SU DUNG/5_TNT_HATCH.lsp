  ;; 2.SAO CHEP HATCH
    (defun c:HC (/ OSM OLDERR 1error ENAME ELIST ETYPE OLD SOL PT1 LAYN )
      (command "UNDO" "BE")
      (setvar "CMDECHO" 0)
      (setq OSM (getvar "OSMODE"))
      (setq OLDERR *error*)
	    (setq *error* 1error)
      (setq ENAME (entsel "\nCHON HATCH")
            ELIST (entget (car ENAME ))
            ETYPE (cdr (assoc 0 ELIST))
            OLD (getvar "CLAYER")
      )
      (if (/= ETYPE "HATCH")
      (prompt "\nCHON LAI HATCH")
        (progn
          (setvar "OSMODE" 0)
          (setq SOL (setvar "HPNAME" (cdr (assoc 2 ELIST))))
          (if (/= SOL "SOLID")
            (progn
              (while (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
                (setq LAYN (cdr (assoc 8 ELIST)))
                (setvar "HPNAME" (cdr (assoc 2 ELIST)))
                (setvar "HPSCALE" (cdr (assoc 41 ELIST)))
                (setvar "HPANG" (cdr (assoc 52 ELIST)))
                (setvar "HPCOLOR" "BYLAYER")                
                (setvar "CLAYER" LAYN )
                (command "BHATCH" PT1 "" )
                (setvar "CLAYER" OLD )                
              )
            )
            (progn
              (while (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
              (setq LAYN (cdr (assoc 8 ELIST)))
              (setvar "HPNAME" (cdr (assoc 2 ELIST)))
              (setvar "HPCOLOR" "BYLAYER")
              (setvar "CLAYER" LAYN )
              (command "BHATCH" PT1 "" )
              (setvar "CLAYER" OLD )
              )
            )
          )
        )
      )
      (setvar "OSMODE" 16383)
      (setvar "CMDECHO" 1)      
      (setq *error* OLDERR)
      (command "UNDO" "END")
      (princ)
    )
  ;; 3.DI CHUYEN HATCH
    (defun c:HV (/ ENAME ELIST ETYPE OLD SOL LAYN PT1 )
      (setvar "CMDECHO" 0)
      (command "UNDO" "BE")
      (setq ENAME (entsel "\nCHON HATCH")
            ELIST (entget (car ENAME))
            ETYPE (cdr (assoc 0 ELIST))
            OLD (getvar "CLAYER")        
      )
      (if (/= ETYPE "HATCH")
      (prompt "\nCHON LAI HATCH")
        (progn
          (setq SOL (setvar "HPNAME" (cdr (assoc 2 ELIST))))
          (if (/= SOL "SOLID")
            (progn
              (setq LAYN (cdr (assoc 8 ELIST)))
              (setvar "HPNAME" (cdr (assoc 2 ELIST)))
              (setvar "HPSCALE" (cdr (assoc 41 ELIST)))
              (setvar "HPANG" (cdr (assoc 52 ELIST)))
              (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
              (setvar "CLAYER" LAYN )
              (entdel (car ENAME))
              (command "BHATCH" PT1 "" )
              (setvar "CLAYER" OLD )
            )
            (progn
              (setq LAYN (cdr (assoc 8 ELIST)))
              (setvar "HPNAME" (cdr (assoc 2 ELIST)))
              (setq PT1 (getpoint "\nCHON POINT TRONG VUNG HATCH"))
              (setvar "CLAYER" LAYN )
              (entdel (car ENAME))
              (command "BHATCH" PT1 "" )
              (setvar "CLAYER" OLD )
            )
          )
        )
      )
      (command "UNDO" "END")
      (princ)
    )
  ;; 4.THAY DOI TY LE HATCH
    (defun c:HS (/ ENAME ELIST ETYPE OSCL HSCL NSCL NLST)
      (setvar "CMDECHO" 0)
      (command "UNDO" "BE")
      (setq ENAME (entsel "\nCHON HATCH")
            ELIST (entget (car ENAME))
            ETYPE (cdr (assoc 0 ELIST))
            OSCL (assoc 41 ELIST)
      )
      (if (/= ETYPE "HATCH")
      (prompt "\nCHON LAI HATCH")
        (progn
          (setq HSCL (getreal (strcat "\nNHAP TY LE HATCH MOI: <" (rtos (cdr OSCL) 2) ">:"))
                NSCL (cons 41 HSCL)
                NLST (subst NSCL OSCL ELIST)
          )
          (entmod NLST)
          (command "HATCHEDIT" ENAME "" "" "" "")
        )
      )
      (command "UNDO" "END")
      (princ) 
    )
