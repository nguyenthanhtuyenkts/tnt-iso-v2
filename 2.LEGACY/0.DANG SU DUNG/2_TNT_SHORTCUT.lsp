    (defun c:D3 (/ B)
          (setvar "CMDECHO" 0)
          (setq ENAME (car (entsel )))
          (setq ENAMELIST (entget ENAME))
          (setq B (cdr (assoc 41 ENAMELIST)))
          (command "DIMSCALE" B )
          (setvar "CMDECHO" 1)
          (princ)
    )
