    (defun c:C1 ( / TILE)
    (setq TILE (getvar "TILEMODE")) 
    (if (= TILE 0)
        (progn
            (setvar "TILEMODE" 1))      
        (progn
            (setvar "TILEMODE" 0))
    )
    (princ))
