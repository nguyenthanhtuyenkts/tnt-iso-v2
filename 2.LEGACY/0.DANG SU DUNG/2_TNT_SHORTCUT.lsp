    (defun c:TT1 (/ ENAME PT1 etrim PT1 )      
      (command "UNDO" "BE")
      (setq ENAME (entsel)
            PT1 (getpoint))
        (if (cond (etrim)
            (T (load "extrim.lisp" "") etrim))
          (etrim (car ENAME) PT1)
        )
      (command "UNDO" "END")
      (princ)
      )
