 ;; 8.PHIM TAT VE GROUP 
    (defun c:g1 ()
      (if (= (getvar "PICKSTYLE") 0)
          (setvar "PICKSTYLE" 1)
          (setvar "PICKSTYLE" 0)
      )
      (princ))
 ;; 9.PHIM TAT CHUNG
    (defun C:PU (/ )
        (setvar "CMDECHO" 0)
        (command "-PURGE" "ALL" "" "N" )
        (command "-PURGE" "R" "" "N" )
        (command ".AUDIT" "Y" )
          (setvar "CMDECHO" 1)
        (princ)
      )
