;;; SETTING BAN DAU
  ;; 1. CAI CAC BIEN HE THONG 
    (setvar "MODEMACRO" "TNT Architecture")
    (defun c:SETTING ()  
    (setvar "cursorsize" 100)                           ;CHINH SIZE CON TRO CHUOT
    (setvar "cursortype" 0)                             ;HIEN THI CURSOR
    (setvar "ISAVEBAK" 1)                               ;TAO FILE BACKUP KHI SAVE
    (setvar "SAVETIME" 15)                              ;TU DONG SAVE FILE 30 PHUT
    (setvar "INSUNITSDEFSOURCE" 4)                      ;SET MILIMETERS KHI CHEN KHOI
    (setvar "INSUNITSDEFTARGET" 4)                      ;SET MILIMETERS KHI XUAT BAN VE
    (setvar "OSOPTIONS" 1)                              ;CHO PHEP BAT DIEM VAO HATCH
    ;(setvar "APERTURE" 15)                             ;DO RONG O VUONG BAT DIEM
    ;(setvar "PICKBOX" 15)                              ;DO RONG O VUONG CHON DIEM
    ;(setvar "GRIPSIZE" 15)                             ;DO RONG O VUONG CHUC NANG
    (setvar "MIRRTEXT" 0)                               ;CHU KHONG BI LAT NGUOC KHI MIRROR
    (setvar "MIRRHATCH" 0)                              ;HATCH KHONG BI LAT NGUOC KHI MIRROR
    (setvar "OSMODE" 16383)                             ;BAT TAT CA BAT DIEM
    (setvar "CANNOSCALE" "1:1" )                        ;TY LE 1:1
    (setvar "LTSCALE" 1)                                ;LTS = 1
    (setvar "ANNOALLVISIBLE" 0 )
    (setvar "ANNOAUTOSCALE" 0 )
    (setvar "SELECTIONEFFECT" 10 )                      ; CHON DOI TUONG KO BI DANG LUOI  
    (setvar "TRANSPARENCYDISPLAY" 0 )
    (setvar "DIMLAYER" "...11_TNT_LINE_DIMENSION")         ;LAYER "DIMENTION"
    (setvar "HPLAYER" "...10_TNT_LINE_HATCH")              ;LAYER "HATCH"
    (setvar "TEXTLAYER" "...9_TNT_LINE_TEXT")              ;LAYER "TEXT"
    (princ)
    )
  ;; 2. TRA MA DXF CUA DOI TUONG
    (defun c:DXF (/ MA MA1 )
    (setq MA (car (entsel)))
    (setq MA1 (entget MA))
    (princ MA1)
    (princ))
